{
  "name": "@donartcha/openlag",
  "version": "0.1.2",
  "description": "Architecture as Code traceability graph generator",
  "type": "module",
  "license": "MPL-2.0",
  "bin": {
    "openlag": "bin/openlag.js"
  },
  "files": [
    "bin",
    "scripts",
    "src",
    "dist",
    "index.html",
    "vite.config.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx scripts/cli/openlag.ts dev",
    "build": "npm run generate-relations && npm run build:web && npm run build:cli",
    "build:web": "vite build",
    "build:cli": "tsup scripts/cli/openlag.ts --format esm --platform node --target node18 --out-dir dist/cli --clean false",
    "check": "npm run typecheck && npm run lint && npm run test && npm run pack:dry-run",
    "generate": "tsx scripts/cli/openlag.ts generate",
    "generate-relations": "tsx scripts/generate-relations.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --test --watch tests/*.test.ts",
    "pack:dry-run": "npm pack --dry-run",
    "clean": "rimraf dist public/graph-data.json",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.10.2",
    "chalk": "^5.4.1",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dagre": "^0.8.5",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.15.0",
    "motion": "^12.23.24",
    "ora": "^8.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
