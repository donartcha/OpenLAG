{
  "name": "openlag",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "openlag": "./bin/openlag.js"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "public/graph-data.json"
  ],
  "scripts": {
    "dev": "npm run generate && vite",
    "generate": "tsx scripts/generate-static-data.ts",
    "build": "npm run generate && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "init": "tsx scripts/init-project.ts",
    "lint": "tsc --noEmit",
    "lint:openlag": "openlag lint --profile develop",
    "lint:openlag:feature": "openlag lint --profile feature",
    "lint:openlag:release": "openlag lint --profile release"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/dagre": "^0.7.54",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.15.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
